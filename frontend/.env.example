# frontend/.env.example — copy to .env and adjust.
#
# By default the dev server is same-origin and proxies /api and /arena
# (including WebSockets) to the backend via vite.config.ts. You normally only
# need VITE_API_KEY.

# Where the Vite dev proxy forwards to (default http://localhost:8000).
# VITE_BACKEND_ORIGIN=http://localhost:8000

# Talk to a remote backend directly, bypassing the dev proxy. Leave BOTH unset
# for same-origin + proxy.
# VITE_API_BASE=https://api.example.com
# VITE_WS_BASE=wss://api.example.com

# Must MATCH the backend's API_KEY. Empty only works while the backend runs
# with ENVIRONMENT=development and no API_KEY configured.
VITE_API_KEY=

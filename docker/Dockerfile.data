# docker/Dockerfile.data
# syntax=docker/dockerfile:1.7
#
# Lumina V3 — data-engine service image.
#
# Audit-driven changes
# --------------------
# * (2.1) Installs from pyproject.toml via `pip install ".[data]"`.
# * (2.4) Base remains python:3.11-slim (no GPU here).

# ----- Stage 1 — builder ----------------------------------------------------
FROM python:3.11-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

ENV UV_COMPILE_BYTECODE=1 \
    UV_HTTP_TIMEOUT=60 \
    PYTHONDONTWRITEBYTECODE=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN mkdir -p backend && touch backend/__init__.py
RUN uv sync --frozen --no-dev --no-install-project --extra data

# ----- Stage 2 — runtime ----------------------------------------------------
FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LUMINA_SERVICE_MODE=ingestion \
    PATH="/app/.venv/bin:$PATH"

RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -g 1000 lumina \
    && useradd -u 1000 -g lumina -m -s /bin/bash lumina

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv
COPY backend ./backend
COPY scripts ./scripts
COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh \
    && chown -R lumina:lumina /app

USER lumina

ENTRYPOINT ["docker-entrypoint.sh"]

# ./docker/Dockerfile.perception
# =============================================================================
# LUMINA V3 - PERCEPTION ENCODING SERVICE (GPU)
# =============================================================================
# The Perception Service embodies Layer 1 of the Chimera architecture —
# the three specialized encoder modules that transform raw multi-modal data
# into dense compressed embedding vectors for the RL agent:
#
#   [A] Temporal Encoder (TFT):
#       Input:  OHLCV candles (1m, 5m, 1h) + technical indicators + static covariates
#       Output: Price Embedding (dim=128) → Redis key: embeddings:price:{ticker}
#       Update: Every 1 minute via Celery Beat scheduler
#
#   [B] Semantic Encoder (Distilled Quant-LLM / DistilRoBERTa-financial):
#       Input:  Raw news text, SEC filings, Twitter/Reddit posts
#       Output: Context Embedding (dim=64) → Redis key: embeddings:news:{ticker}
#       Update: On new article ingestion (event-driven), TTL=3600s
#       Latency target: <100ms inference per document
#
#   [C] Structural Encoder (GATv2 Graph Neural Network):
#       Input:  Rolling 30-day correlation matrix + static sector edges
#       Output: Graph Embedding (dim=32) → Redis key: embeddings:graph:{ticker}
#       Update: Every hour, TTL=7200s
#
# This is the heaviest computational service and REQUIRES GPU access.
# CUDA 12.1 base image is used to support PyTorch 2.x with Flash Attention.
# =============================================================================

# NVIDIA CUDA 12.1 base with cuDNN 8 for PyTorch GPU support
# python3.11 variant bundles the correct Python version
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04 AS base

LABEL org.opencontainers.image.title="Lumina V3 - Perception Encoding Service"
LABEL org.opencontainers.image.description="TFT + Distilled LLM + GATv2 GNN encoder pipeline (GPU)"
LABEL org.opencontainers.image.version="3.0.0"
LABEL org.opencontainers.image.authors="Lumina Quant Lab"

# Set CUDA visible devices (overridden by docker-compose runtime config)
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    UV_NO_CACHE=1 \
    UV_SYSTEM_PYTHON=1 \
    # CUDA memory management: expandable segments reduce fragmentation
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    # Tokenizer parallelism: disabled inside worker processes to avoid forking issues
    TOKENIZERS_PARALLELISM=false \
    # Hugging Face cache: point to a mounted volume for model weight persistence
    HF_HOME=/app/.cache/huggingface \
    TRANSFORMERS_CACHE=/app/.cache/huggingface/transformers

# Install Python 3.11 and required system libraries
# libgomp1: OpenMP runtime required by PyTorch parallel operations
# git: required to clone some PyG (PyTorch Geometric) dependencies at build time
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-dev \
    python3-pip \
    python3.11-venv \
    build-essential \
    libpq-dev \
    libgomp1 \
    git \
    curl \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv==0.4.29

# ---- Dependency Stage ----
FROM base AS dependencies

WORKDIR /app

COPY requirements/base.txt requirements/base.txt
COPY requirements/ml.txt requirements/ml.txt

# Install ML stack:
# - PyTorch 2.x with CUDA 12.1 support (cu121 index)
# - PyTorch Geometric (PyG) for GATv2 GNN implementation
# - Hugging Face Transformers for DistilRoBERTa-financial
# - pytorch-forecasting for Temporal Fusion Transformer
RUN uv pip install --no-cache \
    -r requirements/base.txt \
    -r requirements/ml.txt \
    # PyTorch with CUDA 12.1 — installed separately with the CUDA-specific index
    torch==2.3.1+cu121 \
    torchvision==0.18.1+cu121 \
    --extra-index-url https://download.pytorch.org/whl/cu121

# PyTorch Geometric dependencies (scatter, sparse) must match the PyTorch version
# Using pre-built wheels from the PyG CDN
RUN pip install --no-cache-dir \
    torch-scatter \
    torch-sparse \
    torch-geometric \
    -f https://data.pyg.org/whl/torch-2.3.1+cu121.html

# ---- Final Stage ----
FROM dependencies AS final

WORKDIR /app

# Copy the perception module and its shared dependencies
COPY backend/perception/ ./backend/perception/
COPY backend/feature_store/ ./backend/feature_store/
COPY backend/config/ ./backend/config/
COPY backend/workers/embedding_tasks.py ./backend/workers/embedding_tasks.py
COPY backend/workers/celery_app.py ./backend/workers/celery_app.py
COPY backend/utils/ ./backend/utils/
COPY pyproject.toml ./

# Pre-create Hugging Face cache directory with correct permissions
RUN mkdir -p /app/.cache/huggingface && \
    groupadd --gid 1001 lumina && \
    useradd --uid 1001 --gid lumina --shell /bin/bash --create-home lumina && \
    chown -R lumina:lumina /app

USER lumina

EXPOSE 8002

HEALTHCHECK --interval=60s --timeout=20s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8002/health || exit 1

# The perception service runs as a Celery worker consuming embedding tasks
# (TFT updates, NLP inference, GNN correlation updates) from the Redis queue.
# --concurrency 2: GPU tasks are serialized; 2 workers allow mild parallelism
# --queues perception: isolates perception tasks from general task queues
CMD ["celery", "-A", "backend.workers.celery_app", "worker", \
     "--loglevel=info", \
     "--concurrency=2", \
     "--queues=perception,embeddings", \
     "--hostname=perception@%h"]

# STARTER TEMPLATE — perception inference (GPU recommended)
FROM pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime

WORKDIR /app
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e .

COPY backend ./backend

# TODO: select which encoder to run via env var
CMD ["python", "-m", "backend.perception.temporal.inference"]

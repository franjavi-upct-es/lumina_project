# docker/Dockerfile.api
# syntax=docker/dockerfile:1.7
#
# Lumina V3 — API service image.
#
# Audit-driven changes
# --------------------
# * (2.1) Installs from pyproject.toml via `pip install ".[api]"`. The
#   dependency list lives in ONE place; the previous duplication of
#   wheel lists across four Dockerfiles is gone.
# * (2.4) Base image pinned to `python:3.11-slim` (was already correct
#   here — but documented for completeness).
#
# Layout
# ------
# Two-stage: a builder wheel-cache + a slim runtime. Non-root user uid
# 1000. HEALTHCHECK probes /api/monitoring/health every 30 s.

# ----- Stage 1 — builder ----------------------------------------------------
FROM python:3.11-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

<<<<<<< HEAD
ENV UV_COMPILE_BYTECODE=1 \
    UV_HTTP_TIMEOUT=60 \
    PYTHONDONTWRITEBYTECODE=1

=======
ENV UV_HTTP_TIMEOUT=600 \
    UV_CONCURRENT_DOWNLOADS=4

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency files
COPY pyproject.toml uv.lock ./

# Install shared runtime dependencies from [project].dependencies first.
# We explicitly disable default groups so this layer only contains the common
# packages that every backend service expects (for example loguru and jwt).
RUN uv sync --frozen --no-cache --no-install-project --no-dev --no-default-groups \
    --no-install-package nvidia-nccl-cu12

# Install only the dependency groups this shared image actually needs.
RUN uv sync --frozen --no-cache --no-install-project \
    --no-dev \
    --no-default-groups \
    --inexact \
    --no-install-package torch \
    --no-install-package torchvision \
    --no-install-package torchaudio \
    --no-install-package cuda-bindings \
    --no-install-package cuda-pathfinder \
    --no-install-package cuda-toolkit \
    --no-install-package nvidia-cublas-cu12 \
    --no-install-package nvidia-cuda-cupti-cu12 \
    --no-install-package nvidia-cuda-nvrtc-cu12 \
    --no-install-package nvidia-cuda-runtime-cu12 \
    --no-install-package nvidia-cudnn-cu12 \
    --no-install-package nvidia-cufft-cu12 \
    --no-install-package nvidia-cufile-cu12 \
    --no-install-package nvidia-curand-cu12 \
    --no-install-package nvidia-cusolver-cu12 \
    --no-install-package nvidia-cusparse-cu12 \
    --no-install-package nvidia-cusparselt-cu12 \
    --no-install-package nvidia-nccl-cu12 \
    --no-install-package nvidia-nvjitlink-cu12 \
    --no-install-package nvidia-nvshmem-cu12 \
    --no-install-package nvidia-nvtx-cu12 \
    --no-install-package triton \
    --only-group api \
    --only-group db \
    --only-group data \
    --only-group ml \
    --only-group backtest \
    --only-group celery \
    --only-group mlflow

# Install CPU-only PyTorch into the shared application virtualenv after all
# uv sync steps complete. Installing it earlier would place the wheels in the
# system interpreter, while the services actually run from /app/.venv.
RUN uv pip install --python /app/.venv/bin/python --no-cache \
    https://download.pytorch.org/whl/cpu/torch-2.11.0%2Bcpu-cp311-cp311-manylinux_2_28_x86_64.whl \
    https://download.pytorch.org/whl/cpu/torchvision-0.26.0%2Bcpu-cp311-cp311-manylinux_2_28_x86_64.whl \
    https://download.pytorch.org/whl/cpu/torchaudio-2.11.0%2Bcpu-cp311-cp311-manylinux_2_28_x86_64.whl

# Production stage
FROM python:3.11-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH="/app:/app/backend"

# Install runtime dependencies
>>>>>>> 994b45ea5c7f16817f4caea4d941fa54c203899e
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies from the project metadata.
COPY pyproject.toml uv.lock ./
RUN mkdir -p backend && touch backend/__init__.py
RUN uv sync --frozen --no-dev --no-install-project --extra api

# ----- Stage 2 — runtime ----------------------------------------------------
FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LUMINA_SERVICE_MODE=api \
    PATH="/app/.venv/bin:$PATH"

# libpq5 is the runtime shared object for asyncpg; curl powers HEALTHCHECK.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpq5 curl \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -g 1000 lumina \
    && useradd -u 1000 -g lumina -m -s /bin/bash lumina

WORKDIR /app

# Copy the resolved environment from the builder stage.
COPY --from=builder /app/.venv /app/.venv

# Copy application code last so source edits don't bust the deps layer.
COPY backend ./backend
COPY alembic ./alembic
COPY alembic.ini ./
COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh \
    && chown -R lumina:lumina /app

USER lumina

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl --fail --silent http://localhost:8000/api/monitoring/health \
        > /dev/null || exit 1

ENTRYPOINT ["docker-entrypoint.sh"]

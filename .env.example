# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=lumina
POSTGRES_PASSWORD=your_secure_password_here_change_this
POSTGRES_DB=lumina_db
MLFLOW_DB=lumina_mlflow
POSTGRES_PORT=5435

# ============================================
# Redis Authentication
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ============================================
# Secret Key (FastAPI)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your_secret_key_here_minimum_32_characters_long

# ============================================
# API Keys - use hashed keys for security
# Generate: python3 -c "import hashlib; print(hashlib.sha256(b'your-api-key-here').hexdigest())"
# ============================================
API_KEY_HASHES=[]
REQUIRE_API_KEY=false

# ============================================
# External Data Source API Keys (Optional)
# ============================================
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=


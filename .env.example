# .env.example
# Copy this file to .env (in the same directory as docker-compose.yml)
# and fill in the values. Every variable here is consumed either by
# Pydantic settings (`backend.config.settings`) or by docker-compose at
# build/run time.

# ------- Environment -------
# One of: development, staging, production. Affects log formatting and
# default safety thresholds.
ENVIRONMENT=development
LIVE_TICKERS=SPY,AAPL,MSFT,NVDA,GOOGL,AMZN,TSLA,QQQ
ALLOW_RANDOM_MODELS=false
GRAPH_INFERENCE_INTERVAL_SECONDS=86400
AGENT_TICK_INTERVAL_SECONDS=1.0

# Synthetic profile knobs. For a fully local smoke test, set
# ALLOW_RANDOM_MODELS=true before launching the synthetic-feed profile if
# trained model checkpoints are not present.
SYNTHETIC_FEED_BOOTSTRAP_DAYS=90
SYNTHETIC_FEED_TICK_INTERVAL_SECONDS=1.0
SYNTHETIC_FEED_NEWS_INTERVAL_SECONDS=30
SYNTHETIC_FEED_SEED=7

# ------- Data source selection -------
# Allowed values:
#   "yfinance" — free, recommended for first prototyping (daily granularity)
#   "polygon"  — production, $29/mo Starter or higher (1-min resolution)
DATA_SOURCE=yfinance

# ------- Polygon.io (only needed if DATA_SOURCE=polygon) -------
POLYGON_API_KEY=

# ------- News -------
# NewsAPI free tier is 100 requests/day — sufficient for the prototype.
NEWSAPI_KEY=

# ------- Broker -------
# "paper"  — local PaperBroker (no network, deterministic fills)
# "alpaca" — AlpacaBroker (paper-trading by default; ALPACA_PAPER=true)
BROKER_MODE=paper
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
INITIAL_CAPITAL=100000

# ------- Storage (Docker service-name DNS when running inside compose) -------
# When running OUTSIDE compose (e.g. `make dev`), override to localhost:
#   REDIS_URL=redis://localhost:6379/0
#   TIMESCALE_URL=postgresql://lumina:lumina@localhost:5432/lumina
REDIS_URL=redis://redis:6379/0
TIMESCALE_URL=postgresql://lumina:lumina@timescale:5432/lumina

# ------- MLflow -------
# When running OUTSIDE compose, override to localhost:
#   MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_TRACKING_URI=http://mlflow:5000

# ------- API -------
API_KEY=change_me_in_production
CORS_ORIGINS=http://localhost:5173

# ------- Safety thresholds (read by the Uncertainty Gate + RiskMonitor) -------
UNCERTAINTY_THRESHOLD=0.85
MAX_DRAWDOWN_LIMIT=0.20

# ------- Service-mode dispatcher (Docker only) -------
# Overrides the per-image default in the Dockerfile. Common values:
#   api, migrate, ingestion, tft_inference, semantic_inference,
#   price_stream, news_collector, synthetic_feed,
#   graph_inference, state_assembler, agent_loop,
#   paper_trading, train_agent, sleep
# Leave unset to use the per-image default.
# LUMINA_SERVICE_MODE=

# ------- Uvicorn (api image only) -------
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info

# ------- Spartan Arena -------
# Directory for per-run artifacts (super-state .npy blobs, decisions.jsonl).
ARENA_ARTIFACT_DIR=./artifacts/arena
# If true, run_summarizer may load a small local SLM for end-of-run narratives.
# When false (default), summaries are pure templates — no model loaded.
ARENA_ENABLE_RUN_SUMMARIZER_LLM=false
# Local SLM weights directory. Only consulted when the flag above is true.
ARENA_RUN_SUMMARIZER_MODEL_PATH=
# Default playback multiplier exposed to the frontend (>=1.0).
ARENA_DEFAULT_PLAYBACK_MULTIPLIER=1.0

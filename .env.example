# Environment Configuration for Lumina Project
# Copy this file to .env and fill in with your actual values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=lumina
POSTGRES_PASSWORD=your_secure_password_here_change_this
POSTGRES_DB=lumina_db
MLFLOW_DB=lumina_mlflow
POSTGRES_PORT=5435

# ============================================
# Redis Authentication
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ============================================
# Secret Key (FastAPI)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your_secret_key_here_minimum_32_characters_long

# ============================================
# API Keys - use hashed keys for security
# Generate: python3 -c "import hashlib; print(hashlib.sha256(b'your-api-key-here').hexdigest())"
# ============================================
API_KEY_HASHES=[]
REQUIRE_API_KEY=false

# ============================================
# External Data Source API Keys (Optional)
# ============================================
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# ============================================
# MLflow Configuration
# ============================================
# This is built automatically from POSTGRES_USER, POSTGRES_PASSWORD, and MLFLOW_DB
# MLFLOW_BACKEND_STORE_URI=postgresql://lumina:your_password@timescaledb:5432/lumina_mlflow
# MLFLOW_DEFAULT_ARTIFACT_ROOT=/app/mlartifacts (set in Dockerfile)

# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true
API_PORT=8000
API_BASE_URL=http://localhost:8000
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ALLOWED_HOSTS=localhost,localhost:5000,127.0.0.1,127.0.0.1:5000,mlflow,mlflow:5000
STREAMLIT_PORT=8501
JUPYTER_PORT=8888

# Local host URLs for scripts/tests outside Docker
DATABASE_URL=postgresql://lumina:your_secure_password_here_change_this@localhost:5435/lumina_db
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0
CELERY_BROKER_URL=redis://:your_redis_password_here@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password_here@localhost:6379/2
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501","http://localhost:8000","http://localhost:8888"]

# ============================================
# GPU Configuration (if using GPU workers)
# ============================================
CUDA_VISIBLE_DEVICES=0

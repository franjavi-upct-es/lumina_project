# ------- Environment -------
# One of: development, staging, production. Affects log formatting and
# default safety thresholds.
ENVIRONMENT=development
LIVE_TICKERS=SPY,AAPL,MSFT,NVDA,GOOGL,AMZN,TSLA,QQQ
ALLOW_RANDOM_MODELS=false
GRAPH_INFERENCE_INTERVAL_SECONDS=86400
AGENT_TICK_INTERVAL_SECONDS=1.0
